# Percura Behavioral Data Pipeline - Environment Variables
# Copy this file to .env and fill in your keys

# Required: Groq API key (for behavioral extraction via llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Reddit API credentials (not needed — we use public JSON endpoints)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=percura_scraper/1.0
